local function UpdateOrb()
    local character = Player.Character
    if not character then return end
    local torso = character:FindFirstChild("Torso") or character:FindFirstChild("HumanoidRootPart")
    if not torso then return end
    angle = angle + CONFIG.OrbitSpeed
    local offset = Vector3.new(
        math.cos(angle) * CONFIG.OrbitDistance,
        math.sin(angle * 0.5) * (CONFIG.OrbitDistance * 0.3),
        math.sin(angle) * CONFIG.OrbitDistance
    )
    p.CFrame = CFrame.new(torso.Position + offset)
    local trail = Instance.new("Part", p)
    trail.CFrame = p.CFrame
    trail.FormFactor = Enum.FormFactor.Custom
    trail.Size = Vector3.new(CONFIG.TrailSize, CONFIG.TrailSize, CONFIG.TrailSize)
    trail.BrickColor = BrickColor.new(CONFIG.Color)
    trail.Transparency = CONFIG.TrailTransparency
    trail.CanCollide = false
    trail.Anchored = true
    trail.Material = CONFIG.Material
    trail.TopSurface = Enum.SurfaceType.Smooth
    trail.BottomSurface = Enum.SurfaceType.Smooth
    Debris:AddItem(trail, CONFIG.TrailLifetime)
end

UIS.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.Semicolon then
        CreateTextBar()
    end
    if input.KeyCode == Enum.KeyCode.Return then
        if textBarGui then
            textBarGui:Destroy()
            textBarGui = nil
            textBar = nil
            typing = false
        end
    end
end)

