-- ========== GET COMMAND NAMES FOR AUTOCOMPLETE ==========
local allCommandNames = {}

local function BuildCommandList()
    allCommandNames = {}
    for _, v in pairs(cmds) do
        if v.NAME and v.NAME ~= "" then
            table.insert(allCommandNames, v.NAME:lower())
            if v.ALIAS then
                for _, alias in pairs(v.ALIAS) do
                    if alias ~= "" then
                        table.insert(allCommandNames, alias:lower())
                    end
                end
            end
        end
    end
    table.sort(allCommandNames)
end

BuildCommandList()

local function GetSuggestion(input)
    if input == "" or not input then return "" end
    input = input:lower()
    for _, cmd in pairs(allCommandNames) do
        if cmd:sub(1, #input) == input and cmd ~= input then
            return cmd:sub(#input + 1)
        end
    end
    return ""
end

