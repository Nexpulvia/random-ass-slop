local function CreateTextBar()
    if textBarGui then
        textBarGui:Destroy()
        textBarGui = nil
        textBar = nil
        typing = false
        return
    end
    
    textBarGui = Instance.new("ScreenGui")
    textBarGui.Parent = Player.PlayerGui
    textBarGui.Name = "TextBarGui"
    textBarGui.ResetOnSpawn = false
    
    -- Main text bar container
    local container = Instance.new("Frame", textBarGui)
    container.Size = UDim2.new(1, 0, 0, 40)
    container.Position = UDim2.new(0, 0, 0.5, -20)
    container.BackgroundTransparency = 1
    container.ClipsDescendants = false
    
    -- Suggestion label (ghost text)
    local suggestionLabel = Instance.new("TextLabel", container)
    suggestionLabel.Size = UDim2.new(1, 0, 1, 0)
    suggestionLabel.Position = UDim2.new(0, 0, 0, 0)
    suggestionLabel.BackgroundTransparency = 1
    suggestionLabel.Text = ""
    suggestionLabel.TextColor3 = Color3.new(0.5, 0.5, 0.5)
    suggestionLabel.TextSize = 24
    suggestionLabel.Font = Enum.Font.SourceSans
    suggestionLabel.TextXAlignment = Enum.TextXAlignment.Center
    suggestionLabel.TextYAlignment = Enum.TextYAlignment.Center
    suggestionLabel.ZIndex = 0
    
    -- Actual text box
    textBar = Instance.new("TextBox", container)
    textBar.Size = UDim2.new(1, 0, 1, 0)
    textBar.Position = UDim2.new(0, 0, 0, 0)
    textBar.BackgroundColor3 = Color3.new(0.3, 0.3, 0.3)
    textBar.BackgroundTransparency = 0.2
    textBar.BorderSizePixel = 0
    textBar.TextColor3 = Color3.new(1, 1, 1)
    textBar.Text = ""
    textBar.PlaceholderText = "type something (cmds for list)"
    textBar.PlaceholderColor3 = Color3.new(0.6, 0.6, 0.6)
    textBar.Font = Enum.Font.SourceSans
    textBar.TextSize = 24
    textBar.TextXAlignment = Enum.TextXAlignment.Center
    textBar.TextYAlignment = Enum.TextYAlignment.Center
    textBar.ClearTextOnFocus = false
    textBar.ZIndex = 1
    textBar:CaptureFocus()

    textBar.Focused:Connect(function()
        typing = true
        suggestionText = ""
    end)
    
    textBar:GetPropertyChangedSignal("Text"):Connect(function()
        local currentText = textBar.Text
        suggestionText = GetSuggestion(currentText)
        if suggestionText ~= "" then
            suggestionLabel.Text = currentText .. suggestionText
        else
            suggestionLabel.Text = ""
        end
    end)

    textBar.FocusLost:Connect(function(enterPressed)
        typing = false
        suggestionText = ""
        suggestionLabel.Text = ""
        if enterPressed and textBar.Text ~= "" then
            local cmd = textBar.Text:lower()
            textBar.Text = ""

            if cmd == "cmds" then
                ShowCommandList()
            else
                ExecuteCommand(cmd)
            end

            if textBarGui then
                textBarGui:Destroy()
                textBarGui = nil
                textBar = nil
            end
        end
    end)
    
    -- Update suggestion on text change
    textBar:GetPropertyChangedSignal("Text"):Connect(function()
        local currentText = textBar.Text
        local suggestion = GetSuggestion(currentText)
        if suggestion ~= "" then
            suggestionLabel.Text = currentText .. suggestion
        else
            suggestionLabel.Text = ""
        end
    end)
end

