-- Freecam
local fcEnabled = false
local cam = workspace.CurrentCamera
local cam1 = 0
local cam2 = 0
local cam3 = 0
local k1 = false
local k2 = false
local k3 = false
local k4 = false
local k5 = false
local k6 = false
local cs = 0.5

function movecam()
    local fc = Player.Character:FindFirstChild('xFC')
    if fcEnabled == false then
        repeat
            if Player.Character:FindFirstChild('xFC') then
                local fp = fc.Position
                fc.CFrame = CFrame.new(Vector3.new(fp.X, fp.Y + cam3, fp.Z), cam.CFrame.p) * CFrame.new(cam2, 0, cam1)
                fcEnabled = true
                Player.Character.Head.Anchored = true
            end
            RunService.RenderStepped:Wait()
        until not Player.Character:FindFirstChild('xFC')
        fcEnabled = false
    end
end

UIS.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and Player.Character and Player.Character:FindFirstChild('xFC') then
        local key = input.KeyCode
        if key == Enum.KeyCode.W or key == Enum.KeyCode.Up then
            k1 = true
            cam1 = cs
        elseif key == Enum.KeyCode.S or key == Enum.KeyCode.Down then
            k2 = true
            cam1 = (cs * -1)
        elseif key == Enum.KeyCode.A or key == Enum.KeyCode.Left then
            k3 = true
            cam2 = cs
        elseif key == Enum.KeyCode.D or key == Enum.KeyCode.Right then
            k4 = true
            cam2 = (cs * -1)
        elseif key == Enum.KeyCode.E or key == Enum.KeyCode.Space then
            k5 = true
            cam3 = cs
        elseif key == Enum.KeyCode.Q or key == Enum.KeyCode.LeftControl then
            k6 = true
            cam3 = (cs * -1)
        end
    end
end)

UIS.InputEnded:Connect(function(input, gameProcessed)
    if not gameProcessed and Player.Character and Player.Character:FindFirstChild('xFC') then
        local key = input.KeyCode
        if key == Enum.KeyCode.W or key == Enum.KeyCode.Up then
            k1 = false
            if k2 == false then cam1 = 0 end
        elseif key == Enum.KeyCode.S or key == Enum.KeyCode.Down then
            k2 = false
            if k1 == false then cam1 = 0 end
        elseif key == Enum.KeyCode.A or key == Enum.KeyCode.Left then
            k3 = false
            if k4 == false then cam2 = 0 end
        elseif key == Enum.KeyCode.D or key == Enum.KeyCode.Right then
            k4 = false
            if k3 == false then cam2 = 0 end
        elseif key == Enum.KeyCode.E or key == Enum.KeyCode.Space then
            k5 = false
            if k6 == false then cam3 = 0 end
        elseif key == Enum.KeyCode.Q or key == Enum.KeyCode.LeftControl then
            k6 = false
            if k5 == false then cam3 = 0 end
        end
    end
end)

