        fc.CFrame = CFrame.new(Vector3.new(fp.X, fp.Y + cam3, fp.Z), workspace.CurrentCamera.CFrame.p) * CFrame.new(cam2, 0, cam1)
        Player.Character.Head.Anchored = true
    end
end

local function kp1(inputObject, gameProcessedEvent)
    if not gameProcessedEvent and Player.Character and Player.Character:FindFirstChild('xFC') then
        if inputObject.KeyCode == Enum.KeyCode.W or inputObject.KeyCode == Enum.KeyCode.Up then
            k1 = true; cam1 = cs
        elseif inputObject.KeyCode == Enum.KeyCode.S or inputObject.KeyCode == Enum.KeyCode.Down then
            k2 = true; cam1 = -cs
        elseif inputObject.KeyCode == Enum.KeyCode.A or inputObject.KeyCode == Enum.KeyCode.Left then
            k3 = true; cam2 = cs
        elseif inputObject.KeyCode == Enum.KeyCode.D or inputObject.KeyCode == Enum.KeyCode.Right then
            k4 = true; cam2 = -cs
        elseif inputObject.KeyCode == Enum.KeyCode.E or inputObject.KeyCode == Enum.KeyCode.Space then
            k5 = true; cam3 = cs
        elseif inputObject.KeyCode == Enum.KeyCode.Q or inputObject.KeyCode == Enum.KeyCode.LeftControl then
            k6 = true; cam3 = -cs
        end
    end
end

local function kp2(inputObject, gameProcessedEvent)
    if not gameProcessedEvent and Player.Character and Player.Character:FindFirstChild('xFC') then
        if inputObject.KeyCode == Enum.KeyCode.W or inputObject.KeyCode == Enum.KeyCode.Up then
            k1 = false; if not k2 then cam1 = 0 end
        elseif inputObject.KeyCode == Enum.KeyCode.S or inputObject.KeyCode == Enum.KeyCode.Down then
            k2 = false; if not k1 then cam1 = 0 end
        elseif inputObject.KeyCode == Enum.KeyCode.A or inputObject.KeyCode == Enum.KeyCode.Left then
            k3 = false; if not k4 then cam2 = 0 end
        elseif inputObject.KeyCode == Enum.KeyCode.D or inputObject.KeyCode == Enum.KeyCode.Right then
            k4 = false; if not k3 then cam2 = 0 end
        elseif inputObject.KeyCode == Enum.KeyCode.E or inputObject.KeyCode == Enum.KeyCode.Space then
            k5 = false; if not k6 then cam3 = 0 end
        elseif inputObject.KeyCode == Enum.KeyCode.Q or inputObject.KeyCode == Enum.KeyCode.LeftControl then
            k6 = false; if not k5 then cam3 = 0 end
        end
    end
end

