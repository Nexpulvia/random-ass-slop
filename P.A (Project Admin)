function splitString(str, delim)
    if delim == nil then delim = "," end
    local broken = {}
    for w in string.gmatch(str, "[^" .. delim .. "]+") do
        table.insert(broken, w)
    end
    return broken
end

function isNumber(str)
    return tonumber(str) ~= nil
end

function FindInTable(Table, Name)
    for _, v in pairs(Table) do
        if v == Name then return true end
    end
    return false
end

function getstring(begin)
    begin = begin or 1
    local start = begin - 1
    local AA = ''
    for i = start + 1, #cargs do
        if AA ~= '' then AA = AA .. ' ' .. cargs[i] else AA = cargs[i] end
    end
    return AA
end

function tools(plr)
    if plr.Backpack:FindFirstChildOfClass('Tool') or plr.Character:FindFirstChildOfClass('Tool') then
        return true
    end
end

function r15(plr)
    if plr.Character and plr.Character:FindFirstChildOfClass('Humanoid') then
        return plr.Character:FindFirstChildOfClass('Humanoid').RigType == Enum.HumanoidRigType.R15
    end
    return false
end

function toClipboard(String)
    if not pcall(function()
        local CB = setclipboard or Clipboard.set
        CB(String)
        Notify('Copied to clipboard')
    end) then
        Notify("Your exploit doesn't have the ability to use the clipboard")
    end
end

